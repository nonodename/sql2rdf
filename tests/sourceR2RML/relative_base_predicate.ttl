@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix ex: <http://example.com/ns#>.

# Regression fixture: rr:predicate is given as a bare relative reference
# (not an absolute IRI, CURIE, or column/template value), so its final IRI
# depends entirely on correctly resolving the document's base URI. Used to
# verify that parsing this file via a *relative* filesystem path still
# produces an absolute "file://" base (see R2RMLParser::parse()).
<#TriplesMap1>
    rr:logicalTable [ rr:tableName "EMP" ];
    rr:subjectMap [
        rr:template "http://data.example.com/employee/{EMPNO}";
    ];
    rr:predicateObjectMap [
        rr:predicate <#name>;
        rr:objectMap [ rr:column "ENAME" ];
    ].
