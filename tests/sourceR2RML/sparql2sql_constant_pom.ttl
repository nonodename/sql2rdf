@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix ex: <http://example.com/ns#>.

# Toy fixture for the SPARQL-to-SQL translator: exercises constant predicate
# maps and constant object maps (rr:predicate/rr:object shortcuts) as well as
# the general rr:predicateMap [ rr:constant ... ] form, neither of which
# example_emp_dept.ttl covers.

<#PeopleTriplesMap>
    rr:logicalTable [ rr:tableName "PEOPLE" ];
    rr:subjectMap [
        rr:template "http://data.example.com/person/{ID}";
        rr:class ex:Person;
    ];
    rr:predicateObjectMap [
        rr:predicate ex:status;
        rr:objectMap [ rr:constant ex:Active ];
    ];
    rr:predicateObjectMap [
        rr:predicateMap [ rr:constant ex:name ];
        rr:objectMap [ rr:column "NAME" ];
    ].
